{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,
    "strict": true,
    "moduleResolution": "bundler",
    "declaration": true,
    "sourceMap": true,
    "baseUrl": ".",
    "paths": {
      "@rara/types": ["packages/types/src/index.ts"],
      "@rara/types/*": ["packages/types/src/*"],
      "@rara/utils": ["packages/utils/src/index.ts"],
      "@rara/utils/*": ["packages/utils/src/*"],
      "@rara/mock-data": ["packages/mock-data/src/index.ts"],
      "@rara/mock-data/*": ["packages/mock-data/src/*"],
      "@rara/hooks": ["packages/hooks/src/index.ts"],
      "@rara/hooks/*": ["packages/hooks/src/*"]
    }
  }
}
