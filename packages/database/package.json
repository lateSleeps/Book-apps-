{
  "name": "@rara/database",
  "version": "0.0.1",
  "description": "Supabase database client and utilities for Rara Beauty",
  "private": true,
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js",
    "./client": "./dist/client/index.js"
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "type-check": "tsc --noEmit",
    "test:connection": "node test-connection.js"
  },
  "dependencies": {
    "@rara/types": "workspace:*",
    "@supabase/supabase-js": "^2.38.0",
    "drizzle-orm": "^0.45.2",
    "postgres": "^3.4.9"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "dotenv": "^17.4.2",
    "drizzle-kit": "^0.31.10",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.0"
  }
}
